{
    "algorithm-type-name": "NexusMTFConfluenceStrategy",
    "algorithm-language": "Python",
    "algorithm-location": "strategies/nexus_confluence/main.py",

    "data-folder": "lean-data",
    "results-destination-folder": "lean-results",

    "environment": "backtesting",
    "log-handler": "QuantConnect.Logging.CompositeLogHandler",
    "messaging-handler": "QuantConnect.Messaging.Messaging",
    "job-queue-handler": "QuantConnect.Queues.JobQueue",
    "api-handler": "QuantConnect.Api.Api",

    "maximum-warmup-history-days-look-back": 600,
    "maximum-data-points-per-chart-series": 4000,

    "parameters": {
        "symbol":           "SBIN",
        "risk_pct":         "1.0",
        "atr_len":          "14",
        "atr_sl_norm":      "1.5",
        "atr_sl_high":      "2.5",
        "atr_trail":        "2.5",
        "min_rr":           "1.5",
        "min_score":        "6",
        "swing_len":        "10",
        "liq_len":          "7",
        "liq_margin":       "1.45",
        "ob_len":           "5",
        "min_range_ratio":  "0.70"
    },

    "_to_run_a_reference_strategy": {
        "instruction": "Change algorithm-type-name to one of:",
        "options": [
            "RefStrategy_SpiderWave",
            "RefStrategy_LiquiditySweep",
            "RefStrategy_SupplyDemand",
            "RefStrategy_PriceActionConcepts"
        ]
    },

    "_run_command": "python engine-wrapper/run_backtest.py --config strategies/nexus_confluence/lean-config.json"
}
